/* app.wxss — 全局样式 */

page {
  background-color: #0f0f23;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 主色调 */
.text-primary { color: #4fc3f7; }
.text-accent { color: #ff7043; }
.text-success { color: #66bb6a; }
.text-warning { color: #ffa726; }
.text-danger { color: #ef5350; }

.bg-primary { background-color: #4fc3f7; }
.bg-card { background-color: #1a1a3e; }

/* 卡片 */
.card {
  background: linear-gradient(135deg, #1a1a3e, #16213e);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(79, 195, 247, 0.15);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #4fc3f7, #0288d1);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(79, 195, 247, 0.3);
}

.btn-primary::after { border: none; }

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-accent {
  background: linear-gradient(135deg, #ff7043, #e64a19);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 112, 67, 0.3);
}

.btn-accent::after { border: none; }

/* 标题 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #90a4ae;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 24rpx 0;
}

/* 安全区域适配 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
