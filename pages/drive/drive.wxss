/* pages/drive/drive.wxss */
.drive-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0a0a1a;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  inset: 0;
  z-index: 50;
  background: #0a0a1a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  text-align: center;
}

.loading-train {
  font-size: 80rpx;
  animation: trainMove 1.5s ease-in-out infinite;
}

@keyframes trainMove {
  0%, 100% { transform: translateX(-20rpx); }
  50% { transform: translateX(20rpx); }
}

.loading-text {
  color: #90a4ae;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.loading-dots {
  color: #4fc3f7;
  font-size: 32rpx;
  margin-top: 10rpx;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.game-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 顶部HUD */
.hud-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 100rpx 30rpx 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, transparent 100%);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.speed-display {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.speed-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #4fc3f7;
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
  text-shadow: 0 0 20rpx rgba(79, 195, 247, 0.5);
}

.speed-unit {
  font-size: 24rpx;
  color: #90a4ae;
}

.hud-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.hud-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* HUD角色头像 */
.hud-char {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.hud-char-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.hud-face {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  left: 50%;
  top: 4rpx;
  transform: translateX(-50%);
  z-index: 2;
}

.hud-eyes {
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 6rpx;
}

.hud-eye {
  width: 5rpx;
  height: 6rpx;
  background: #333;
  border-radius: 50%;
}

.hud-shirt {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 46rpx;
  height: 20rpx;
  border-radius: 23rpx 23rpx 0 0;
  z-index: 1;
}

.hud-char-name {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 信号灯 */
.signal-bar {
  position: absolute;
  top: 200rpx;
  left: 30rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.signal-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.signal-dot.green { background: #66bb6a; box-shadow: 0 0 12rpx #66bb6a; }
.signal-dot.yellow { background: #ffa726; box-shadow: 0 0 12rpx #ffa726; animation: blink 0.8s infinite; }
.signal-dot.red { background: #ef5350; box-shadow: 0 0 12rpx #ef5350; animation: blink 0.4s infinite; }

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.signal-text {
  font-size: 24rpx;
  color: #eceff1;
}

/* 事件弹窗 */
.event-overlay {
  position: absolute;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.event-card {
  background: linear-gradient(135deg, #1a1a3e, #16213e);
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  margin: 0 40rpx;
  border: 2rpx solid rgba(79, 195, 247, 0.3);
  text-align: center;
}

.event-text {
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.event-btn {
  width: 100%;
}

/* 控制区 */
.controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, transparent 100%);
  padding: 30rpx;
}

.speed-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.speed-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s, background 0.3s;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.ctrl-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
}

.ctrl-btn::after { border: none; }

.ctrl-btn.brake {
  background: linear-gradient(135deg, #ef5350, #c62828);
}

.ctrl-btn.accelerate {
  background: linear-gradient(135deg, #4fc3f7, #0288d1);
}

.ctrl-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.ctrl-label {
  font-size: 24rpx;
  color: #fff;
}

.bottom-bar {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.pause-btn, .finish-btn {
  font-size: 26rpx;
  color: #90a4ae;
  padding: 10rpx 20rpx;
}
