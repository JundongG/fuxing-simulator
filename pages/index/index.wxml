<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="logo">🚄</view>
    <view class="title">高铁五七班</view>
    <view class="subtitle">选一个小司机，开启你的高铁之旅</view>
  </view>

  <!-- 角色选择 -->
  <view class="section-title">👤 选择小司机</view>
  <scroll-view class="char-scroll" scroll-x enable-flex>
    <view
      class="char-card {{selectedChar && selectedChar.id === item.id ? 'active' : ''}}"
      wx:for="{{characters}}"
      wx:key="id"
      bindtap="onSelectChar"
      data-char="{{item}}"
    >
      <!-- CSS绘制卡通头像 -->
      <view class="char-avatar" style="background: {{item.bgColor}};">
        <view class="avatar-face">
          <!-- 头发 -->
          <view class="hair hair-{{item.id}}"></view>
          <!-- 脸 -->
          <view class="face" style="background: {{item.skinColor}};">
            <!-- 眼睛 -->
            <view class="eyes">
              <view class="eye"></view>
              <view class="eye"></view>
            </view>
            <!-- 嘴巴 -->
            <view class="mouth"></view>
            <!-- 腮红 -->
            <view class="blush left"></view>
            <view class="blush right"></view>
          </view>
          <!-- 衣服 -->
          <view class="shirt" style="background: {{item.shirtColor}};"></view>
        </view>
      </view>
      <view class="char-name">{{item.name}}</view>
      <view class="char-tag" style="background: {{item.color}}; color: #fff;">{{item.tag}}</view>
    </view>
  </scroll-view>

  <!-- 选中角色描述 -->
  <view class="char-desc" wx:if="{{selectedChar}}">
    <text class="char-desc-text">{{selectedChar.desc}}</text>
  </view>

  <!-- AI输入区 -->
  <view class="ai-section">
    <view class="input-wrapper">
      <input
        class="ai-input"
        placeholder="例：CR400复兴号穿越武夷山隧道"
        placeholder-class="placeholder"
        value="{{aiInput}}"
        bindinput="onInputChange"
        bindconfirm="onGenerate"
        maxlength="50"
      />
      <view class="input-icon">✨</view>
    </view>
    <button class="btn-primary generate-btn {{loading ? 'loading' : ''}}" bindtap="onGenerate" disabled="{{loading}}">
      <block wx:if="{{loading}}">生成中...</block>
      <block wx:else>🎮 生成并驾驶</block>
    </button>
  </view>

  <!-- 热门线路 -->
  <view class="section-title">🔥 热门线路</view>
  <view class="route-grid">
    <view
      class="route-card"
      wx:for="{{hotRoutes}}"
      wx:key="id"
      bindtap="onSelectRoute"
      data-route="{{item}}"
    >
      <view class="route-cover" style="background: {{item.gradient}}">
        <view class="route-emoji">{{item.emoji}}</view>
      </view>
      <view class="route-info">
        <view class="route-name">{{item.name}}</view>
        <view class="route-distance">{{item.distance}}km</view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">⚠️ 本产品为娱乐模拟，非真实驾驶训练</text>
  </view>
</view>
