/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f23, #1a1a2e);
  padding: 40rpx 30rpx;
}

.result-header {
  text-align: center;
  padding: 60rpx 0 30rpx;
}

.trophy {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.scene-name {
  font-size: 26rpx;
  color: #90a4ae;
  margin-top: 8rpx;
}

.score-card {
  text-align: center;
  padding: 40rpx;
  margin: 30rpx 0;
}

.score-big {
  font-size: 120rpx;
  font-weight: bold;
  font-family: 'DIN Alternate', monospace;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  color: #78909c;
  margin-top: 8rpx;
}

.grade-badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin: 30rpx 0;
}

.stat-item {
  background: linear-gradient(135deg, #1a1a3e, #16213e);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(79, 195, 247, 0.1);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4fc3f7;
  font-family: monospace;
}

.stat-unit {
  font-size: 22rpx;
  color: #78909c;
  margin-left: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #90a4ae;
  margin-top: 6rpx;
}

.summary-card {
  background: linear-gradient(135deg, #1a1a3e, #16213e);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 30rpx 0;
  border: 1rpx solid rgba(79, 195, 247, 0.12);
}

.summary-label {
  font-size: 26rpx;
  color: #4fc3f7;
  margin-bottom: 12rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #b0bec5;
  line-height: 1.8;
}

.actions {
  margin-top: 40rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  color: #b0bec5;
  font-size: 26rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn-secondary::after { border: none; }

.back-home {
  text-align: center;
  color: #546e7a;
  font-size: 26rpx;
  margin-top: 30rpx;
  padding: 20rpx;
}
