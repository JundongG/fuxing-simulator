/* pages/scene/scene.wxss */
.scene-page {
  min-height: 100vh;
  background: #0f0f23;
  padding-bottom: 180rpx;
}

.back-btn {
  position: fixed;
  top: 0;
  left: 0;
  padding: 100rpx 30rpx 20rpx;
  color: #4fc3f7;
  font-size: 28rpx;
  z-index: 10;
}

.cover {
  height: 450rpx;
  position: relative;
  overflow: hidden;
}

.cover-bg {
  position: absolute;
  inset: 0;
  opacity: 0.8;
}

.cover-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 120rpx;
  filter: drop-shadow(0 4rpx 20rpx rgba(0,0,0,0.5));
}

.scene-info {
  padding: 30rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.scene-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.scene-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.tag {
  background: rgba(79, 195, 247, 0.15);
  color: #4fc3f7;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(79, 195, 247, 0.2);
}

.card {
  background: linear-gradient(135deg, #1a1a3e, #16213e);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(79, 195, 247, 0.12);
}

.card-label {
  font-size: 26rpx;
  color: #4fc3f7;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.card-text {
  font-size: 28rpx;
  color: #b0bec5;
  line-height: 1.8;
}

.landmarks {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.landmark {
  background: rgba(255, 255, 255, 0.06);
  color: #eceff1;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 角色信息条 */
.char-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin: -20rpx 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 3;
}

.char-bar-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.mini-face {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  left: 50%;
  top: 4rpx;
  transform: translateX(-50%);
  z-index: 2;
}

.mini-eyes {
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8rpx;
}

.mini-eye {
  width: 6rpx;
  height: 7rpx;
  background: #333;
  border-radius: 50%;
}

.mini-shirt {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 54rpx;
  height: 22rpx;
  border-radius: 27rpx 27rpx 0 0;
  z-index: 1;
}

.char-bar-info {
  flex: 1;
  margin-left: 16rpx;
}

.char-bar-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  display: block;
}

.char-bar-role {
  font-size: 20rpx;
  color: #78909c;
  display: block;
  margin-top: 2rpx;
}

.char-bar-badge {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.start-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: linear-gradient(0deg, #0f0f23 60%, transparent);
}

.start-btn {
  width: 100%;
  font-size: 34rpx;
  letter-spacing: 4rpx;
}
